{
  "homepage": "https://MichaelWen24.github.io/resume",
  "name": "react-resume-template",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "predeploy": "yarn build",
    "export": "next export",
    "deploy": "yarn build && gh-pages -d out",
    "build": "yarn compile && yarn next build --webpack",
    "clean": "rm -rf build-tsc .next",
    "compile": "yarn run -T tsc --build --verbose",
    "dev": "yarn compile && yarn next dev --webpack",
    "lint": "yarn run -T prettier --write './src/**/*.{js,jsx,json,ts,tsx}' && eslint './src/**/*.{js,jsx,ts,tsx}' --fix --max-warnings=0",
    "start": "yarn next start",
    "sitemap": "yarn next-sitemap"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "autoprefixer": "^10.4.22",
    "classnames": "^2.5.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ts-pattern": "^5.3.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.4",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/tailwindcss": "^3.1.0",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "cssnano": "^7.0.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-module-resolver": "^1.5.0",
    "eslint-plugin-monorepo": "^0.3.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-memo": "^0.0.3",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-keys-fix": "^1.1.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.49",
    "postcss-preset-env": "^10.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "sass": "^1.83.0",
    "sort-package-json": "^2.10.1",
    "stylelint": "^16.10.0",
    "stylelint-config-recommended": "^14.0.1",
    "stylelint-order": "^6.0.4",
    "stylelint-prettier": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "autoprefixer": "10.4.22"
  },
  "overrides": {
    "minimatch@^3.0.0": "3.1.4"
  }
}
